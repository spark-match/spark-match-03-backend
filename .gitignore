__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
.python-version
.mypy_cache/
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
*.egg-info/
dist/
build/
*.egg

