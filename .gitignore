# -----------------------------------------------------------------------------
# Node.js / npm (workspaces compartidos)
# -----------------------------------------------------------------------------
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# -----------------------------------------------------------------------------
# Build artifacts (TypeScript compilado)
# -----------------------------------------------------------------------------
dist/
build/
out/
**/dist/
**/build/
**/out/
*.tsbuildinfo
.tsbuildinfo

# -----------------------------------------------------------------------------
# Lambda Layer artifacts (build.sh genera estos)
# -----------------------------------------------------------------------------
layers/*/nodejs/
layers/*/*.zip
layers/*/optimized/

# -----------------------------------------------------------------------------
# AWS SAM
# -----------------------------------------------------------------------------
.aws-sam/
sam-app/
*.sam.yaml
# samconfig.toml SI se commitea (es config del equipo, no secreto)

# -----------------------------------------------------------------------------
# Serverless Framework (NO usamos, pero por si acaso)
# -----------------------------------------------------------------------------
.serverless/
*.serverless

# -----------------------------------------------------------------------------
# CloudFormation / CDK outputs
# -----------------------------------------------------------------------------
cdk.out/
cdk.context.json
cfn-templates/
packaged.yaml

# -----------------------------------------------------------------------------
# Coverage / Testing
# -----------------------------------------------------------------------------
coverage/
**/coverage/
*.lcov
.nyc_output/

# -----------------------------------------------------------------------------
# Variables de entorno y secretos (NUNCA commitear)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local
!.env.example

# -----------------------------------------------------------------------------
# AWS credentials y configs locales
# -----------------------------------------------------------------------------
.aws/
**/.aws/credentials
**/.aws/config

