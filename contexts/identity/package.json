{
  "name": "@spark-match/context-identity",
  "version": "0.1.0",
  "private": true,
  "description": "Identity bounded context: auth, users, profiles, sessions",
  "type": "module",
  "main": "./dist/handlers/index.js",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "local:register": "sam local invoke IdentityRegisterFunction -e events/register.json",
    "local:login": "sam local invoke IdentityLoginFunction -e events/login.json"
  },
  "dependencies": {
    "@spark-match/shared": "0.1.0",
    "kysely": "^0.27.0",
    "pg": "^8.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
